{
  "manifest_version": 3,
  "name": "Wingman",
  "description": "AI-powered email assistant — get feedback on grammar, tone, clarity, and more.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs",
    "identity"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://localhost:3000/*",
    "https://mail.google.com/*",
    "https://*.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "config.js",
        "auth.js",
        "content-api.js",
        "content-compose.js",
        "content-analyzer.js",
        "content-leads.js",
        "content-reminders.js",
        "content-resume.js",
        "content-search.js",
        "content-sidebar.js",
        "content-init.js"
      ],
      "css": [
        "content-variables.css",
        "content-gmail-layout.css",
        "content-sidebar-shell.css",
        "content-sidebar-auth.css",
        "content-sidebar-reminders.css",
        "content-sidebar-analyzer.css",
        "content-sidebar-leads.css",
        "content-sidebar-search.css",
        "content-sidebar-settings.css",
        "content-reminder-toast.css",
        "content-semantic-search.css"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}